# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
GEMINI_INTAKE_MODEL=gemini-3.5-flash-lite

# Email and admin access
ADMIN_EMAILS=
RESEND_API_KEY=
EMAIL_FROM=Somahorse.ai <onboarding@your-verified-domain.com>
EMAIL_REPLY_TO=support@your-verified-domain.com
CRON_SECRET=
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Paddle Billing (use sandbox credentials for local development)
PADDLE_API_KEY=
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=
PADDLE_WEBHOOK_SECRET_KEY=
PADDLE_ENVIRONMENT=sandbox
PADDLE_TAX_CATEGORY=standard

# Currency display and talent payout conversion
# Paddle supplies checkout conversion for its supported payment currencies.
# This server-only key covers broader ISO currencies such as NGN and BWP.
OPEN_EXCHANGE_RATES_APP_ID=
